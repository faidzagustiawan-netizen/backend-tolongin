datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. USER MANAGEMENT & SECURITY
// ==========================================

enum Role {
  TALENT
  COMPANY
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(TALENT)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  talentProfile       TalentProfile?
  companyProfile      CompanyProfile?
  teamMemberships     CompanyMember[]
  activityLogs        CompanyActivityLog[]
  discussions         Discussion[]
  notifications       Notification[]
  tokenTransactions   TokenTransaction[]
  paymentTransactions PaymentTransaction[]

  @@map("users")
}

model TalentProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  headline    String?
  avatarUrl   String?
  bio         String?
  resumeUrl   String?
  skills      String[]
  githubUrl   String?
  linkedinUrl String?
  figmaUrl    String?

  // AI Identity & Security
  faceVerificationStatus VerificationStatus @default(UNVERIFIED)
  ktpNik                 String? @unique // Untuk memastikan 1 identitas KTP 1 akun
  biometricDataHash      String? @unique // Untuk verifikasi wajah anti-joki & memastikan 1 wajah 1 akun
  biometricFeatureVector Json?   // Vektor fitur biometrik 64-dimensi untuk deteksi real-time anti-joki

  // Leaderboard & Demographics
  location     String?
  roleCategory String?

  // Privacy & Encryption
  encryptedPrivateFace String? // Gambar selfie terenkripsi AES-256 untuk liveness
  encryptedKtpData     String? // Gambar KTP terenkripsi AES-256 untuk audit

  // Gamification & Economy
  xp           Int @default(0)
  level        Int @default(1)
  tokenBalance Int @default(0)

  showcasedSubmissionIds String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments       ChallengeEnrollment[]
  submissions       Submission[]
  portfolios        Portfolio[]
  earnedBadges      TalentBadge[]
  createdChallenges Challenge[]           @relation("CreatedChallenges")

  @@map("talent_profiles")
}

// ==========================================
// 2. COMPANY & SUBSCRIPTION MODEL
// ==========================================

enum SubscriptionTier {
  STARTUP
  KONGLOMERAT
  CUSTOM
}

model CompanyProfile {
  id          String  @id @default(uuid())
  userId      String  @unique // Akun PIC Perusahaan
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  logoUrl     String?
  description String?
  websiteUrl  String?
  industry    String
  companySize String?
  location    String?
  linkedinUrl String?

  // Validasi KYB (Know Your Business) & Subscription
  kybStatus             VerificationStatus @default(UNVERIFIED)
  subscriptionTier      SubscriptionTier   @default(STARTUP)
  subscriptionExpiresAt DateTime?

  // Accountability & Team
  trustScore Int @default(100)
  inviteCode String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  challenges   Challenge[]
  teamMembers  CompanyMember[]
  activityLogs CompanyActivityLog[]

  @@map("company_profiles")
}

model CompanyMember {
  id        String   @id @default(uuid())
  companyId String
  userId    String   @unique
  role      String   @default("MEMBER") // OWNER, ADMIN, RECRUITER
  joinedAt  DateTime @default(now())

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_members")
}

model CompanyActivityLog {
  id         String   @id @default(uuid())
  companyId  String
  userId     String
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_activity_logs")
}

// ==========================================
// 3. CHALLENGE DIRECTORY & AI GENERATION
// ==========================================

enum ChallengeType {
  COMPANY
  PUBLIC
}

enum ChallengeCategory {
  UI_UX
  FRONTEND
  BACKEND
  DATA_SCIENCE
  MARKETING
  PRODUCT
}

enum ChallengeDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ChallengeStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model Challenge {
  id        String          @id @default(uuid())
  companyId String?
  company   CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  talentId  String?
  creator   TalentProfile?  @relation("CreatedChallenges", fields: [talentId], references: [id], onDelete: SetNull)

  challengeType ChallengeType @default(COMPANY)
  title         String
  slug        String              @unique
  summary     String
  description String // Detail studi kasus / problem statement
  category    ChallengeCategory
  difficulty  ChallengeDifficulty

  // Resource & Aset
  datasetUrl        String?
  mockApiUrl        String?
  brandGuidelineUrl String?
  briefAttachments  Json? // For images, videos, documents, external links related to brief

  // Rubrik Penilaian (Penyimpanan JSON untuk fleksibilitas kriteria)
  gradingRubric     Json
  rewardDescription String?
  startsAt          DateTime?
  deadlineAt        DateTime?
  isPrivate         Boolean         @default(false)
  status            ChallengeStatus @default(DRAFT)

  // AI Challenge Generator Tracking
  createdByAi  Boolean @default(false)
  aiPromptUsed String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments ChallengeEnrollment[]
  submissions Submission[]
  discussions Discussion[]
  components  ChallengeComponent[]
  sections    ChallengeSection[]

  @@map("challenges")
}

model ChallengeSection {
  id          String        @id @default(uuid())
  challengeId String
  challenge   Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  order       Int           @default(0)

  components  ChallengeComponent[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("challenge_sections")
}

enum ComponentType {
  MULTIPLE_CHOICE
  ESSAY
  FILE_UPLOAD
  VIDEO_UPLOAD
  URL_SUBMISSION
  LIVE_CODING
}

model ChallengeComponent {
  id          String        @id @default(uuid())
  challengeId String
  challenge   Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  
  sectionId   String?
  section     ChallengeSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  type        ComponentType
  question    String
  description String?
  options     Json?         // Jika MULTIPLE_CHOICE: [{id, text, isCorrect}]
  metadata    Json?         // Konfigurasi lain misal: language untuk LIVE_CODING, durasi untuk VIDEO
  points      Int           @default(10)
  order       Int           @default(0)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  responses   ComponentResponse[]

  @@map("challenge_components")
}

// ==========================================
// 4. WORKSPACE & SUBMISSION
// ==========================================

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  SUBMITTED
  EVALUATED
  DROPPED
}

model ChallengeEnrollment {
  id          String        @id @default(uuid())
  talentId    String
  talent      TalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  status      EnrollmentStatus @default(ENROLLED)
  ndaSignedAt DateTime?
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  draftData   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions Submission[]

  @@unique([talentId, challengeId])
  @@map("challenge_enrollments")
}

enum SubmissionStatus {
  PENDING_AI
  UNDER_REVIEW
  PASSED
  FAILED
}

enum HiringStatus {
  NONE
  SHORTLISTED
  INTERVIEW_INVITED
  HIRED
  REJECTED
}

model Submission {
  id           String              @id @default(uuid())
  enrollmentId String
  enrollment   ChallengeEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  talentId     String
  talent       TalentProfile       @relation(fields: [talentId], references: [id], onDelete: Cascade)
  challengeId  String
  challenge    Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  // Solusi yang dikumpulkan
  solutionFilesUrl String?
  repositoryUrl    String?
  figmaUrl         String?
  liveDemoUrl      String?
  notes            String?

  // AI Correction & Integrity
  aiPlagiarismScore   Float? // 0.0 - 100.0%
  aiCorrectionSummary String? // Analisis otomatis dari AI
  aiScore             Float? // Skor awal dari AI (0-100)

  // Review Manusia & Keputusan
  finalScore       Float? // Skor dari rekruter
  reviewerFeedback String? // Ulasan kualitatif
  status           SubmissionStatus @default(PENDING_AI)
  hiringStatus     HiringStatus     @default(NONE)
  autoPassed       Boolean          @default(false)
  evaluatedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolio          Portfolio?
  componentResponses ComponentResponse[]

  @@map("submissions")
}

model ComponentResponse {
  id           String             @id @default(uuid())
  submissionId String
  submission   Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  componentId  String
  component    ChallengeComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  // Nilai jawaban fleksibel
  textValue    String? // Untuk Essay, URL, Live Coding, Option ID
  fileUrl      String? // Untuk File/Video

  score        Float?  // Penilaian
  aiFeedback   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("component_responses")
}

// ==========================================
// 5. DISKUSI & Q&A
// ==========================================

model Discussion {
  id          String    @id @default(uuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  message  String
  parentId String? // Untuk thread balasan (self-referencing)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("discussions")
}

// ==========================================
// 6. PORTFOLIO SHOWCASE
// ==========================================

model Portfolio {
  id           String        @id @default(uuid())
  talentId     String
  talent       TalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)
  submissionId String        @unique
  submission   Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  isPublic         Boolean @default(true)
  verifiedBadgeUrl String?
  showcaseSummary  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("portfolios")
}

// ==========================================
// 7. GAMIFICATION & NOTIFICATIONS
// ==========================================

model Badge {
  id          String @id @default(uuid())
  title       String @unique
  description String
  iconUrl     String
  requiredXp  Int    @default(0)

  earnedBy TalentBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("badges")
}

model TalentBadge {
  id       String        @id @default(uuid())
  talentId String
  talent   TalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge         @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime      @default(now())

  @@unique([talentId, badgeId])
  @@map("talent_badges")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ==========================================
// 8. TOKEN ECONOMY
// ==========================================

enum TokenType {
  EARN
  SPEND
}

model TokenTransaction {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  type        TokenType
  description String
  createdAt   DateTime  @default(now())

  @@map("token_transactions")
}

// ==========================================
// 9. PAYMENT GATEWAY (XENDIT)
// ==========================================

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum PaymentType {
  TOKEN_TOPUP
  SUBSCRIPTION
}

model PaymentTransaction {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  externalId      String        @unique // Xendit external_id
  checkoutUrl     String?       // Xendit invoice_url
  amount          Int
  status          PaymentStatus @default(PENDING)
  paymentType     PaymentType
  
  metadata        Json?         // Untuk menyimpan data spesifik paket (misal: tokenAmount)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payment_transactions")
}
