# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/tolongin_db?schema=public"

# Authentication / Security
JWT_SECRET="generate-a-secure-random-secret-key-here"
JWT_EXPIRATION="7d"

# Port
PORT=3000

# Storage (Cloudflare R2)
STORAGE_ACCESS_KEY="your-r2-access-key"
STORAGE_SECRET_KEY="your-r2-secret-key"
STORAGE_ENDPOINT="your-r2-endpoint"
STORAGE_BUCKET_NAME="tolongin-bucket"

# AI Services
OPENAI_API_KEY="sk-proj-your-openai-key"
GEMINI_API_KEY="AIzaSy-your-gemini-key"

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"

# Email / Resend
RESEND_API_KEY="re_your-resend-key"

# Sentry
SENTRY_DSN="your-sentry-dsn"
