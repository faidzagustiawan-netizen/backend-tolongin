# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Authentication / Security
JWT_SECRET="your_super_secret_jwt_key_here"
JWT_EXPIRATION="7d"

# Port
PORT=3001

# Cloudflare R2 / AWS S3 Storage
STORAGE_ENDPOINT="https://your_account_id.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY="your_access_key"
STORAGE_SECRET_KEY="your_secret_key"
STORAGE_BUCKET_NAME="media-tolongin"
STORAGE_PUBLIC_URL="https://pub-your_public_url.r2.dev"

# AI Evaluation Engine (OpenAI / Gemini LLM)
OPENAI_API_KEY="sk-proj-..."
GEMINI_API_KEY="AIza..."

# Sentry (Error Tracking & Performance Monitoring)
SENTRY_DSN="https://<key>@<organization>.ingest.sentry.io/<project_id>"
